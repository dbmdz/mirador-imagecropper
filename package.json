{
  "name": "mirador-imagecropper",
  "version": "1.0.0",
  "description": "Mirador 4 plugin to retrieve the image url for the selected area",
  "keywords": [
    "iiif",
    "mirador",
    "mirador4",
    "mirador-plugin",
    "react-component"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbmdz/mirador-imagecropper.git"
  },
  "license": "MIT",
  "author": "Matthias Lindinger <matthias.lindinger@bsb-muenchen.de>",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:demo && npm run build:plugin",
    "prebuild:demo": "rimraf demo/dist",
    "build:demo": "BUILD_MODE=demo vite build",
    "prebuild:plugin": "rimraf dist",
    "build:plugin": "vite build",
    "format": "eslint . --ext js,jsx --fix --max-warnings 0 --report-unused-disable-directives",
    "lint": "eslint . --ext js,jsx --max-warnings 0 --report-unused-disable-directives",
    "prepublishOnly": "npm run build",
    "prepreview": "npm run build:demo",
    "preview": "BUILD_MODE=demo vite preview",
    "start": "vite"
  },
  "dependencies": {
    "mui-image": "^1.0.9"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "mirador": "^4.1.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "vite": "^8.1.0"
  },
  "peerDependencies": {
    "mirador": "4.x",
    "react": "19.x",
    "react-dom": "19.x"
  },
  "engines": {
    "npm": ">=11.0.0"
  }
}

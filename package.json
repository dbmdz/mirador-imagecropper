{
  "name": "mirador-imagecropper",
  "version": "0.1.9",
  "description": "Mirador 3 plugin to retrieve the image url for the selected area",
  "keywords": [
    "iiif",
    "mirador",
    "mirador3",
    "mirador-plugin",
    "react-component"
  ],
  "homepage": "",
  "repository": "https://github.com/dbmdz/mirador-imagecropper",
  "license": "MIT",
  "author": "Matthias Lindinger <matthias.lindinger@bsb-muenchen.de>",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:demo && npm run build:plugin",
    "prebuild:demo": "rimraf demo/dist",
    "build:demo": "BUILD_MODE=demo vite build",
    "prebuild:plugin": "rimraf dist",
    "build:plugin": "vite build",
    "format": "eslint . --ext js,jsx,ts,tsx --fix --max-warnings 0 --report-unused-disable-directives",
    "lint": "eslint . --ext js,jsx,ts,tsx --max-warnings 0 --report-unused-disable-directives",
    "prepublishOnly": "npm run build",
    "prepreview": "npm run build:demo",
    "preview": "BUILD_MODE=demo vite preview",
    "start": "vite"
  },
  "dependencies": {
    "material-ui-image": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.5.0",
    "mirador": "^3.3.0",
    "prettier": "^3.8.3",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "rimraf": "^6.1.3",
    "vite": "^8.0.10"
  },
  "peerDependencies": {
    "@material-ui/core": "4.x",
    "@material-ui/icons": "4.x",
    "@material-ui/lab": "^4.0.0-alpha.61",
    "lodash": "4.x",
    "mirador": "3.x",
    "openseadragon": "2.x",
    "prop-types": "15.x",
    "react": "16.x",
    "react-dom": "16.x",
    "react-rnd": "10.x",
    "redux-saga": "1.x",
    "reselect": "4.x"
  },
  "engines": {
    "npm": ">=8.0.0"
  }
}
